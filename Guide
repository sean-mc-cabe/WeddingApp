function Write-Log {
    param([string]$Text)
    $txtLog.AppendText($Text + "`r`n")
    $txtLog.SelectionStart = $txtLog.Text.Length
    $txtLog.ScrollToCaret()
    [System.Windows.Forms.Application]::DoEvents()
}

$btnSrc.Add_Click({
    $dlg = New-Object System.Windows.Forms.FolderBrowserDialog
    $dlg.Description = 'Select the unzipped solution export folder'
    if ($txtSrc.Text -and (Test-Path $txtSrc.Text)) { $dlg.SelectedPath = $txtSrc.Text }
    if ($dlg.ShowDialog() -eq 'OK') {
        $txtSrc.Text = $dlg.SelectedPath
        if (-not $txtOut.Text) { $txtOut.Text = Join-Path $dlg.SelectedPath 'NotebookDocs' }
    }
})

$btnOut.Add_Click({
    $dlg = New-Object System.Windows.Forms.FolderBrowserDialog
    $dlg.Description = 'Select the output folder'
    if ($txtOut.Text -and (Test-Path $txtOut.Text)) { $dlg.SelectedPath = $txtOut.Text }
    if ($dlg.ShowDialog() -eq 'OK') { $txtOut.Text = $dlg.SelectedPath }
})

$btnOpen.Add_Click({
    if ($txtOut.Text -and (Test-Path $txtOut.Text)) { Start-Process explorer.exe $txtOut.Text }
})

$btnRun.Add_Click({
    $src = $txtSrc.Text.Trim()
    $out = $txtOut.Text.Trim()
    if (-not $src -or -not (Test-Path $src)) {
        [System.Windows.Forms.MessageBox]::Show('Please select a valid unzipped solution folder.', 'Missing input', 'OK', 'Warning') | Out-Null
        return
    }
    if (-not $out) {
        [System.Windows.Forms.MessageBox]::Show('Please select an output folder.', 'Missing input', 'OK', 'Warning') | Out-Null
        return
    }
    $btnRun.Enabled = $false
    $btnOpen.Enabled = $false
    $txtLog.Clear()
    $lblStatus.Text = 'Running... the window may pause briefly while Excel is written.'
    [System.Windows.Forms.Application]::DoEvents()
    try {
        $output = Invoke-Conversion -UnpackedFolder $src -OutputFolder $out -RawYamlLineCap ([int]$numCap.Value) *>&1
        foreach ($line in $output) { Write-Log ([string]$line) }
        $lblStatus.Text = 'Done.'
        $btnOpen.Enabled = $true
    } catch {
        Write-Log ''
        Write-Log ('ERROR: ' + $_.Exception.Message)
        $lblStatus.Text = 'Failed - see log.'
        try { Get-Process EXCEL -ErrorAction SilentlyContinue | Stop-Process -Force } catch {}
        [System.Windows.Forms.MessageBox]::Show($_.Exception.Message, 'Conversion failed', 'OK', 'Error') | Out-Null
    } finally {
        $btnRun.Enabled = $true
    }
})

[void]$form.ShowDialog()
