function Release-Com { param($Obj) if ($null -ne $Obj) { try { [void][System.Runtime.InteropServices.Marshal]::ReleaseComObject($Obj) } catch {} } }

function Write-Sheet {
    param($Workbook,[string]$Name,[string[]]$Headers,$Rows,[int]$Index)
    if ($Index -eq 1) { $ws = $Workbook.Worksheets.Item(1) } else { $ws = $Workbook.Worksheets.Add([System.Reflection.Missing]::Value, $Workbook.Worksheets.Item($Workbook.Worksheets.Count)) }
    $ws.Name = $Name
    for ($c=0; $c -lt $Headers.Count; $c++) { $ws.Cells.Item(1,$c+1).Value2 = $Headers[$c] }
    $r = 2
    foreach ($row in $Rows) {
        for ($c=0; $c -lt $Headers.Count; $c++) {
            $val = $row[$c]
            if ($null -eq $val) { $val = '' }
            $ws.Cells.Item($r,$c+1).Value2 = [string]$val
        }
        $r++
    }
    $ws.Rows.Item(1).Font.Bold = $true
    $used = $ws.UsedRange
    $used.Columns.AutoFit() | Out-Null
    foreach ($col in $used.Columns) { if ($col.ColumnWidth -gt 80) { $col.ColumnWidth = 80 } }
    Release-Com $used
    Release-Com $ws
}

$excel = $null; $wb = $null
try {
    $excel = New-Object -ComObject Excel.Application
    $excel.Visible = $false
    $excel.DisplayAlerts = $false
    $wb = $excel.Workbooks.Add()
    while ($wb.Worksheets.Count -gt 1) { $wb.Worksheets.Item($wb.Worksheets.Count).Delete() }

    $tableRows = @(); foreach ($t in $tables) { $tableRows += ,@($t.Logical,$t.Display,$t.Columns) }
    Write-Sheet -Workbook $wb -Name 'Tables' -Headers @('Logical','Display','Columns') -Rows $tableRows -Index 1

    $colRows = @(); foreach ($c in $columns) { $colRows += ,@($c.Table,$c.Logical,$c.Display,$c.Type,$c.Required,$c.Choices) }
    Write-Sheet -Workbook $wb -Name 'Columns' -Headers @('Table','Column Logical','Column Display','Type','Required','Choices') -Rows $colRows -Index 2

    $relRows = @(); foreach ($r in $rels) { $relRows += ,@($r.Name,$r.Type,$r.Referencing,$r.Referenced,$r.ViaAttribute) }
    Write-Sheet -Workbook $wb -Name 'Relationships' -Headers @('Name','Type','Referencing / First','Referenced / Second','Via Attribute') -Rows $relRows -Index 3

    $formRows = @(); foreach ($f in $forms) { $formRows += ,@($f.Table,$f.Form,$f.Type,$f.Tab,$f.Section,$f.Field) }
    Write-Sheet -Workbook $wb -Name 'Forms' -Headers @('Table','Form','Type','Tab','Section','Field') -Rows $formRows -Index 4

    $viewRows = @(); foreach ($v in $views) { $viewRows += ,@($v.Table,$v.View,$v.IsDefault,$v.Columns,$v.Sort,$v.Filter) }
    Write-Sheet -Workbook $wb -Name 'Views' -Headers @('Table','View','IsDefault','Columns','Sort','Filter') -Rows $viewRows -Index 5

    $topicRows = @()
    foreach ($b in $bots) {
        $yaml = $b.Raw
        if ($yaml.Length -gt 32000) { $yaml = $yaml.Substring(0,32000) + "`r`n... [truncated; full body exceeds Excel cell limit]" }
        $topicRows += ,@(
            $b.DisplayName, $b.ComponentType,
            ($b.Triggers -join ' | '),
            ($b.GlobalsSet -join ', '),
            ($b.GlobalsRead -join ', '),
            ($b.TopicVarsSet -join ', '),
            (($b.Actions | Select-Object -Unique) -join ', '),
            ($b.Knowledge -join ' | '),
            $b.LineCount,
            $yaml
        )
    }
    Write-Sheet -Workbook $wb -Name 'Topics' -Headers @('Topic','Type','Triggers','Globals Set','Globals Read','Topic Vars Set','Action Kinds','Knowledge Refs','Lines','Full YAML') -Rows $topicRows -Index 6

    $wb.Worksheets.Item(1).Activate()
    if (Test-Path $xlsxPath) { Remove-Item $xlsxPath -Force }
    $wb.SaveAs($xlsxPath, $xlOpenXMLWorkbook)
    $wb.Close($false)
} finally {
    if ($excel) { $excel.Quit() }
    Release-Com $wb
    Release-Com $excel
    [GC]::Collect(); [GC]::WaitForPendingFinalizers()
}
Write-Host "Wrote $xlsxPath"

$word = $null
try {
    $word = New-Object -ComObject Word.Application
    $word.Visible = $false

    function New-Doc { $script:Doc = $word.Documents.Add(); $script:Sel = $word.Selection }
    function W-Title($txt) { $script:Sel.Style = $script:Doc.Styles.Item($wdTitle); $script:Sel.TypeText([string]$txt); $script:Sel.TypeParagraph() }
    function W-H($lvl,$txt) { $script:Sel.Style = $script:Doc.Styles.Item($lvl); $script:Sel.TypeText([string]$txt); $script:Sel.TypeParagraph() }
    function W-P($txt) { $script:Sel.Style = $script:Doc.Styles.Item($wdNormal); $script:Sel.TypeText([string]$txt); $script:Sel.TypeParagraph() }
    function W-Code($txt) {
        $script:Sel.Style = $script:Doc.Styles.Item($wdNormal)
        $script:Sel.Font.Name = 'Consolas'; $script:Sel.Font.Size = 8
        foreach ($line in ([string]$txt -split "`r?`n")) { $script:Sel.TypeText($line); $script:Sel.TypeParagraph() }
        $script:Sel.Font.Name = 'Calibri'; $script:Sel.Font.Size = 11
    }
    function Save-Doc($path) { if (Test-Path $path) { Remove-Item $path -Force }; $script:Doc.SaveAs2($path, $wdFormatDocx); $script:Doc.Close() }

    New-Doc
    W-Title 'Solution Component Inventory'
    W-H $wdHeading1 'Solution'
    W-P ("Unique name: " + $inv.UniqueName)
    W-P ("Version: " + $inv.Version)
    W-P ("Publisher: " + $inv.Publisher + "  (prefix: " + $inv.Prefix + ")")
    W-P ("Managed: " + $inv.Managed)
    W-H $wdHeading1 'Component counts'
    W-P ("Tables: " + $tables.Count)
    W-P ("Forms (rows): " + $forms.Count)
    W-P ("Views: " + $views.Count)
    W-P ("Model-driven apps: " + $apps.Count)
    W-P ("Site maps: " + $maps.Count)
    W-P ("Agent topics: " + $bots.Count)
    W-P ("Cloud flows / workflows: " + $inv.WorkflowCount)
    W-P ("Global choices: " + $inv.GlobalChoiceCount)
    W-P ("Connection references: " + $inv.ConnectionRefCount)
    W-P ("Environment variables: " + $inv.EnvVariableCount)
    W-H $wdHeading1 'Tables'
    if ($tables.Count -eq 0) { W-P 'None found.' }
    foreach ($t in $tables) { W-P ("- " + $t.Display + "  (" + $t.Logical + ", " + $t.Columns + " columns)") }
    W-H $wdHeading1 'Model-driven apps'
    if ($apps.Count -eq 0) { W-P 'None found.' }
    foreach ($a in $apps) { W-P ("- " + $a.Display + "  (" + $a.Unique + ")") }
    W-H $wdHeading1 'Agents'
    if ($botCfg.Name) { W-P ("Bot: " + $botCfg.Name) }
    if ($bots.Count -eq 0) { W-P 'No topics found.' }
    foreach ($b in $bots) { W-P ("- " + $b.DisplayName + "  [" + $b.ComponentType + "]") }
    Save-Doc $invDocx
    Write-Host "Wrote $invDocx"

    New-Doc
    W-Title 'Model-Driven App Specification'
    W-H $wdHeading1 'Apps'
    if ($apps.Count -eq 0) { W-P 'No model-driven apps found in this solution.' }
    foreach ($a in $apps) { W-P ("- " + $a.Display + "  (" + $a.Unique + ")") }
    W-H $wdHeading1 'Site maps'
    if ($maps.Count -eq 0) { W-P 'No site maps found.' }
    $surfaced = New-Object System.Collections.ArrayList
    foreach ($m in $maps) {
        W-H $wdHeading2 ("Site map: " + $m.Name)
        foreach ($area in $m.Areas) {
            W-H $wdHeading3 ("Area: " + $area.Title)
            foreach ($grp in $area.Groups) {
                W-P ("  Group: " + $grp.Title)
                foreach ($sa in $grp.SubAreas) {
                    $label = $sa.Title; if (-not $label) { $label = $sa.Entity }
                    $target = if ($sa.Entity) { "table: " + $sa.Entity } elseif ($sa.Url) { "url: " + $sa.Url } else { '' }
                    W-P ("    - " + $label + "  (" + $target + ")")
                    if ($sa.Entity -and -not $surfaced.Contains($sa.Entity)) { [void]$surfaced.Add($sa.Entity) }
                }
            }
        }
    }
    W-H $wdHeading1 'Tables surfaced across all site maps'
    if ($surfaced.Count -eq 0) { W-P 'None resolved.' }
    foreach ($e in $surfaced) { W-P ("- " + $e) }
    W-H $wdHeading1 'Views by table (per-location filters live here)'
    if ($views.Count -eq 0) { W-P 'No views found.' }
    $viewsByTable = $views | Group-Object Table
    foreach ($g in $viewsByTable) {
        W-H $wdHeading2 ("Table: " + $g.Name)
        foreach ($v in $g.Group) {
            $def = if ($v.IsDefault -eq '1') { ' [default]' } else { '' }
            W-P ("- " + $v.View + $def)
            if ($v.Filter) { W-P ("    filter: " + $v.Filter) }
            if ($v.Sort) { W-P ("    sort: " + $v.Sort) }
            if ($v.Columns) { W-P ("    columns: " + $v.Columns) }
        }
    }
    Save-Doc $mdaDocx
    Write-Host "Wrote $mdaDocx"

    New-Doc
    W-Title 'Agent Design'
    if ($botCfg.Name) { W-P ("Bot: " + $botCfg.Name) }
    if ($botCfg.Instructions) {
        W-H $wdHeading1 'System instructions'
        W-Code $botCfg.Instructions
    }
    $globalSetMap = @{}
    $globalReadMap = @{}
    foreach ($b in $bots) {
        foreach ($g in $b.GlobalsSet) { if (-not $globalSetMap.ContainsKey($g)) { $globalSetMap[$g] = New-Object System.Collections.ArrayList }; [void]$globalSetMap[$g].Add($b.DisplayName) }
        foreach ($g in $b.GlobalsRead) { if (-not $globalReadMap.ContainsKey($g)) { $globalReadMap[$g] = New-Object System.Collections.ArrayList }; [void]$globalReadMap[$g].Add($b.DisplayName) }
    }
    $allGlobals = @($globalSetMap.Keys + $globalReadMap.Keys | Select-Object -Unique | Sort-Object)
    if ($allGlobals.Count -gt 0) {
        W-H $wdHeading1 'Global variables cross-reference'
        foreach ($g in $allGlobals) {
            W-H $wdHeading3 ("Global." + $g)
            $setBy = if ($globalSetMap.ContainsKey($g)) { ($globalSetMap[$g] | Select-Object -Unique) -join ', ' } else { '(not set in any topic)' }
            $readBy = if ($globalReadMap.ContainsKey($g)) { ($globalReadMap[$g] | Select-Object -Unique) -join ', ' } else { '(not read)' }
            W-P ("Set by: " + $setBy)
            W-P ("Read by: " + $readBy)
        }
    }
    foreach ($b in $bots) {
        W-H $wdHeading1 ("Topic: " + $b.DisplayName)
        if ($b.ComponentType) { W-P ("Component type: " + $b.ComponentType + "    (" + $b.LineCount + " lines of YAML; full body in DataDictionary.xlsx > Topics)") }
        W-H $wdHeading2 'Trigger phrases'
        if ($b.Triggers.Count -eq 0) { W-P 'None detected.' }
        foreach ($t in $b.Triggers) { W-P ("- " + $t) }
        if ($b.GlobalsSet.Count -gt 0) {
            W-H $wdHeading2 'Global variables set here'
            foreach ($g in $b.GlobalsSet) { W-P ("- Global." + $g) }
        }
        if ($b.GlobalsRead.Count -gt 0) {
            W-H $wdHeading2 'Global variables read (set elsewhere)'
            foreach ($g in $b.GlobalsRead) { W-P ("- Global." + $g) }
        }
        if ($b.TopicVarsSet.Count -gt 0) {
            W-H $wdHeading2 'Topic variables set'
            foreach ($tv in $b.TopicVarsSet) { W-P ("- Topic." + $tv) }
        }
        if ($b.Actions.Count -gt 0) {
            W-H $wdHeading2 'Action kinds used'
            foreach ($act in ($b.Actions | Select-Object -Unique)) { W-P ("- " + $act) }
        }
        if ($b.Knowledge.Count -gt 0) {
            W-H $wdHeading2 'Knowledge / search / binding references'
            foreach ($k in $b.Knowledge) { W-P ("- " + $k) }
        }
    }
    Save-Doc $agentDocx
    Write-Host "Wrote $agentDocx"
} finally {
    if ($word) { $word.Quit() }
    Release-Com $word
    [GC]::Collect(); [GC]::WaitForPendingFinalizers()
}

Write-Host ''
Write-Host 'Done. Add these to your Copilot Notebook:'
Write-Host "  $xlsxPath"
Write-Host "  $invDocx"
Write-Host "  $mdaDocx"
Write-Host "  $agentDocx"
