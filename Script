function Write-Log {
    param([string]$Message)
    $line = "$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')  $Message"
    Add-Content -Path $LogPath -Value $line
    Write-Host $line
}

function Invoke-WithRetry {
    param(
        [scriptblock]$ScriptBlock,
        [int]$MaxAttempts = 3,
        [int]$DelaySeconds = 2,
        [string]$ActionName = "Action"
    )

    $attempt = 0
    while ($attempt -lt $MaxAttempts) {
        $attempt++
        try {
            return & $ScriptBlock
        }
        catch {
            if ($attempt -ge $MaxAttempts) { throw }
            Write-Log "$ActionName failed on attempt $attempt. Retrying in $DelaySeconds sec. Error: $($_.Exception.Message)"
            Start-Sleep -Seconds $DelaySeconds
        }
    }
}

function Start-Word {
    $word = New-Object -ComObject Word.Application
    $word.Visible = $false
    $word.DisplayAlerts = 0
    return $word
}

function Stop-Word($word) {
    if ($word) {
        try { $word.Quit() } catch {}
        try { [void][System.Runtime.InteropServices.Marshal]::ReleaseComObject($word) } catch {}
        [gc]::Collect()
        [gc]::WaitForPendingFinalizers()
    }
}

function Safe-Name([string]$Name) {
    $invalid = [System.IO.Path]::GetInvalidFileNameChars()
    foreach ($char in $invalid) {
        $Name = $Name.Replace($char, "_")
    }
    return $Name.Trim().TrimEnd(".")
}

function Get-RelativeFolder([string]$sourceUrl, [string]$sourceRoot) {
    $relativePath = $sourceUrl.Substring($sourceRoot.Length).TrimStart("/")
    $relativeFolder = [System.IO.Path]::GetDirectoryName($relativePath)
    if ($relativeFolder -eq "." -or $null -eq $relativeFolder) { $relativeFolder = "" }
    return ($relativeFolder -replace "\\","/").Trim("/")
}

function Get-Category([string]$relativeFolder) {
    if (-not $relativeFolder) { return "Uncategorised" }

    $parts = $relativeFolder -split "/"
    return $parts[0]
}

function Ensure-DocumentLibrary {
    param([string]$LibraryTitle)

    $list = Get-PnPList -Identity $LibraryTitle -ErrorAction SilentlyContinue
    if (-not $list) {
        if ($DryRun) {
            Write-Log "[DRY RUN] Would create library: $LibraryTitle"
            return $null
        }
        Write-Log "Creating library: $LibraryTitle"
        $list = Invoke-WithRetry -ActionName "Create library $LibraryTitle" -ScriptBlock {
            New-PnPList -Title $LibraryTitle -Template DocumentLibrary -OnQuickLaunch:$false
        }
    }
    else {
        Write-Log "Library already exists: $LibraryTitle"
    }

    return $list
}

function Ensure-FieldXml {
    param(
        [string]$ListName,
        [string]$InternalName,
        [string]$FieldXml
    )

    $existing = Get-PnPField -List $ListName -Identity $InternalName -ErrorAction SilentlyContinue
    if ($existing) { return }

    if ($DryRun) {
        Write-Log "[DRY RUN] Would create field: $ListName / $InternalName"
        return
    }

    Write-Log "Creating field: $ListName / $InternalName"
    Invoke-WithRetry -ActionName "Create field $InternalName" -ScriptBlock {
        Add-PnPFieldFromXml -List $ListName -FieldXml $FieldXml | Out-Null
    }
}

